@Pizzeria.API_HostAddress = http://localhost:5202

# Tras hacer sign-in o sign-up, copia aquí el accessToken de la respuesta.
# Todos los requests protegidos llevan 'Authorization: Bearer {{accessToken}}'.
@accessToken = paste-access-token-here
@refreshToken = paste-refresh-token-here


############################################
# Auth (sign-up / sign-in / refresh / sign-out / me)
############################################

### Sign-up: crea un usuario con rol Client y devuelve tokens
POST {{Pizzeria.API_HostAddress}}/api/auth/sign-up
Content-Type: application/json

{
  "email": "alice@test.com",
  "password": "Password123!"
}

### Sign-in (admin sembrado desde .env, o el Client que acabas de crear)
POST {{Pizzeria.API_HostAddress}}/api/auth/sign-in
Content-Type: application/json

{
  "email": "admin@pizzeria.local",
  "password": "change_me_on_first_run"
}

### Refresh: cambia el par (access, refresh) por uno nuevo
POST {{Pizzeria.API_HostAddress}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Sign-out: revoca el refresh token actual (requiere access token válido)
POST {{Pizzeria.API_HostAddress}}/api/auth/sign-out
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### /me: datos del usuario actual
GET {{Pizzeria.API_HostAddress}}/api/auth/me
Authorization: Bearer {{accessToken}}


############################################
# Ingredients
############################################

### Crear ingrediente: masa (requiere Admin)
POST {{Pizzeria.API_HostAddress}}/api/ingredients
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "ING-MASA",
  "name": "Masa",
  "stock": 50,
  "pricePerUnit": 1.5,
  "supplier": "Harinas del Sur"
}

### Crear ingrediente: salsa (requiere Admin)
POST {{Pizzeria.API_HostAddress}}/api/ingredients
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "ING-SALSA",
  "name": "Salsa de tomate",
  "stock": 10,
  "pricePerUnit": 0.02,
  "supplier": "Conservas Italia"
}

### Crear ingrediente: queso (requiere Admin)
POST {{Pizzeria.API_HostAddress}}/api/ingredients
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "ING-QUESO",
  "name": "Queso mozzarella",
  "stock": 15,
  "pricePerUnit": 0.04,
  "supplier": "Lácteos del Valle"
}

### Crear ingrediente: albahaca (requiere Admin)
POST {{Pizzeria.API_HostAddress}}/api/ingredients
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "ING-ALBAHACA",
  "name": "Albahaca",
  "stock": 2,
  "pricePerUnit": 0.5,
  "supplier": "Hierbas Frescas"
}

### Listar ingredientes (cualquier autenticado)
GET {{Pizzeria.API_HostAddress}}/api/ingredients
Authorization: Bearer {{accessToken}}
Accept: application/json

### Consultar uno (cualquier autenticado)
GET {{Pizzeria.API_HostAddress}}/api/ingredients/ING-QUESO
Authorization: Bearer {{accessToken}}
Accept: application/json

### Reponer stock (requiere Admin)
PATCH {{Pizzeria.API_HostAddress}}/api/ingredients/ING-QUESO/stock
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "quantity": 5
}

### Subir varias imágenes al ingrediente en una sola request
### Repetir el campo 'files' por cada imagen. 'altTexts' es opcional; se empareja
### por índice (i-ésimo altText ↔ i-ésimo file). Ajusta las rutas de ./samples/*.
POST {{Pizzeria.API_HostAddress}}/api/ingredients/ING-QUESO/images
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----PizzeriaBoundary

------PizzeriaBoundary
Content-Disposition: form-data; name="altTexts"

Queso rallado sobre tabla
------PizzeriaBoundary
Content-Disposition: form-data; name="altTexts"

Bloque de mozzarella entero
------PizzeriaBoundary
Content-Disposition: form-data; name="files"; filename="queso-rallado.jpg"
Content-Type: image/jpeg

< ./samples/queso-rallado.jpg
------PizzeriaBoundary
Content-Disposition: form-data; name="files"; filename="queso-bloque.jpg"
Content-Type: image/jpeg

< ./samples/queso-bloque.jpg
------PizzeriaBoundary--

### Borrar imagen del ingrediente (requiere Admin; reemplaza {guid}.ext por el key devuelto al subirla)
DELETE {{Pizzeria.API_HostAddress}}/api/ingredients/ING-QUESO/images/ingredients/ING-QUESO/{guid}.jpg
Authorization: Bearer {{accessToken}}


############################################
# Pizzas
############################################

### Crear pizza Margarita (requiere Admin)
POST {{Pizzeria.API_HostAddress}}/api/pizzas
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Margarita",
  "basePrice": 8,
  "ingredients": [
    { "ingredientCode": "ING-MASA", "quantity": 1 },
    { "ingredientCode": "ING-SALSA", "quantity": 0.2 },
    { "ingredientCode": "ING-QUESO", "quantity": 0.3 },
    { "ingredientCode": "ING-ALBAHACA", "quantity": 0.01 }
  ]
}

### Listar pizzas (cualquier autenticado)
GET {{Pizzeria.API_HostAddress}}/api/pizzas
Authorization: Bearer {{accessToken}}
Accept: application/json

### Calcular costo (cualquier autenticado; reemplaza {pizzaId} por el Id que devolvió el POST)
GET {{Pizzeria.API_HostAddress}}/api/pizzas/{pizzaId}/cost
Authorization: Bearer {{accessToken}}
Accept: application/json

### Subir varias imágenes a una pizza en una sola request
### Repetir 'files' por cada imagen; 'altTexts' opcional y por índice.
POST {{Pizzeria.API_HostAddress}}/api/pizzas/{pizzaId}/images
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----PizzeriaBoundary

------PizzeriaBoundary
Content-Disposition: form-data; name="altTexts"

Margarita lista para servir
------PizzeriaBoundary
Content-Disposition: form-data; name="altTexts"

Detalle de la masa
------PizzeriaBoundary
Content-Disposition: form-data; name="files"; filename="margarita-1.jpg"
Content-Type: image/jpeg

< ./samples/margarita-1.jpg
------PizzeriaBoundary
Content-Disposition: form-data; name="files"; filename="margarita-2.jpg"
Content-Type: image/jpeg

< ./samples/margarita-2.jpg
------PizzeriaBoundary--

### Borrar imagen de la pizza (requiere Admin; reemplaza {pizzaId} y {guid}.ext por el key devuelto)
DELETE {{Pizzeria.API_HostAddress}}/api/pizzas/{pizzaId}/images/pizzas/{pizzaId}/{guid}.jpg
Authorization: Bearer {{accessToken}}


############################################
# Delivery persons (repartidores)
############################################

### Crear repartidor (requiere Admin)
POST {{Pizzeria.API_HostAddress}}/api/delivery-persons
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "REP-001",
  "name": "Juan Pérez",
  "phone": "555-1234"
}

### Listar repartidores (requiere Admin)
GET {{Pizzeria.API_HostAddress}}/api/delivery-persons
Authorization: Bearer {{accessToken}}
Accept: application/json


############################################
# Orders (pedidos)
############################################

### Crear pedido (cualquier autenticado; el pedido queda asociado al user del token)
POST {{Pizzeria.API_HostAddress}}/api/orders
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerName": "Ana Gómez",
  "customerPhone": "555-9876",
  "items": [
    { "pizzaId": "{pizzaId}", "quantity": 2 }
  ]
}

### Listar pedidos (requiere Admin)
GET {{Pizzeria.API_HostAddress}}/api/orders
Authorization: Bearer {{accessToken}}
Accept: application/json

### Consultar un pedido (Admin ve cualquiera; Client solo el suyo)
GET {{Pizzeria.API_HostAddress}}/api/orders/{orderId}
Authorization: Bearer {{accessToken}}
Accept: application/json

### Cambiar a "InPreparation" (requiere Admin; reemplaza {orderId})
PATCH {{Pizzeria.API_HostAddress}}/api/orders/{orderId}/status
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": "InPreparation"
}

### Cambiar a "OnTheWay" (requiere Admin; asigna un repartidor disponible)
PATCH {{Pizzeria.API_HostAddress}}/api/orders/{orderId}/status
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": "OnTheWay"
}

### Cambiar a "Delivered" (requiere Admin; libera al repartidor)
PATCH {{Pizzeria.API_HostAddress}}/api/orders/{orderId}/status
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": "Delivered"
}
