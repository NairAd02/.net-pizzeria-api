# Copia este archivo a `.env` en la raíz del repo y rellena con tus valores.
# .env NO se sube a git (ver .gitignore).

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pizzeria
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# --- Auth / JWT ---------------------------------------------------------------
# JWT_SECRET debe tener al menos 32 bytes. Generar uno con, p. ej.:
#   openssl rand -base64 48
# o en PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=change_me_to_a_random_string_of_at_least_32_bytes_xxxxxxxx
JWT_ISSUER=pizzeria-api
JWT_AUDIENCE=pizzeria-api-clients
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# Seed del primer admin: si al arrancar no hay ningún Admin en la BD, se crea
# uno con estas credenciales. En arranques siguientes no pasa nada (idempotente).
# Si dejas ambas vacías, la app arranca sin sembrar nada.
INITIAL_ADMIN_EMAIL=admin@pizzeria.local
INITIAL_ADMIN_PASSWORD=change_me_on_first_run

# --- Storage S3-compatible ----------------------------------------------------
# Todos los proveedores S3-compatibles se configuran con estas mismas variables.
# Para cambiar de proveedor basta con editar este bloque (cero cambios en C#).
#
# Ejemplo abajo: Supabase Storage. Al final del archivo hay más plantillas
# para AWS S3, Cloudflare R2 y MinIO.

STORAGE_PROVIDER=supabase
STORAGE_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=<supabase-s3-access-key>
STORAGE_SECRET_ACCESS_KEY=<supabase-s3-secret-key>
STORAGE_BUCKET=pizzeria-images
# URL base pública para servir los archivos. Supabase usa este patrón:
STORAGE_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/pizzeria-images
STORAGE_FORCE_PATH_STYLE=true

# Opcionales (tienen defaults sensatos):
# STORAGE_MAX_FILE_SIZE_MB=5
# STORAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/avif

# --- Plantillas alternativas (comentadas) -------------------------------------
#
# AWS S3 nativo:
#   STORAGE_PROVIDER=aws
#   STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com
#   STORAGE_REGION=us-east-1
#   STORAGE_ACCESS_KEY_ID=AKIA...
#   STORAGE_SECRET_ACCESS_KEY=...
#   STORAGE_BUCKET=pizzeria-images
#   STORAGE_PUBLIC_BASE_URL=https://pizzeria-images.s3.us-east-1.amazonaws.com
#   STORAGE_FORCE_PATH_STYLE=false
#
# Cloudflare R2:
#   STORAGE_PROVIDER=r2
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_REGION=auto
#   STORAGE_ACCESS_KEY_ID=...
#   STORAGE_SECRET_ACCESS_KEY=...
#   STORAGE_BUCKET=pizzeria-images
#   STORAGE_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev          # o tu dominio público de R2
#   STORAGE_FORCE_PATH_STYLE=true
#
# MinIO local:
#   STORAGE_PROVIDER=minio
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_REGION=us-east-1
#   STORAGE_ACCESS_KEY_ID=minioadmin
#   STORAGE_SECRET_ACCESS_KEY=minioadmin
#   STORAGE_BUCKET=pizzeria-images
#   STORAGE_PUBLIC_BASE_URL=http://localhost:9000/pizzeria-images
#   STORAGE_FORCE_PATH_STYLE=true
